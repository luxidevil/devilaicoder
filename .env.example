NODE_ENV=production
PORT=80
BASE_PATH=/
PUBLIC_APP_URL=http://YOUR_SERVER_IP_OR_DOMAIN

# Postgres connection for the newer Luxi workspace
DATABASE_URL=postgresql://luxi:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/luxi

# Basic admin auth shown by the frontend on first load
ADMIN_CREDS=LUXI:CHANGE_ME_ADMIN_PASSWORD

# Session signing secret for the API server
SESSION_SECRET=CHANGE_ME_SESSION_SECRET

# Active AI provider defaults
AI_PROVIDER=anthropic
AI_MODEL=qwen3-coder-80b

# Anthropic / Claude-compatible gateway configuration
ANTHROPIC_MODEL=qwen3-coder-80b
ANTHROPIC_BASE_URL=https://www.aicostheta.com
ANTHROPIC_AUTH_TOKEN=CHANGE_ME_ANTHROPIC_GATEWAY_TOKEN

# Optional Vertex AI configuration
# Keep these present if you want to switch the active provider to `vertex`
# from the admin UI without re-editing env on the server.
VERTEX_API_KEY=CHANGE_ME_VERTEX_API_KEY
VERTEX_MODEL=gemini-2.5-pro
VERTEX_BASE_URL=https://aiplatform.googleapis.com/v1beta1/publishers/google
